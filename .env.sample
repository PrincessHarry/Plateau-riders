# =============================================================
# PLATEAU RIDERS — Environment Variables
# =============================================================
# Copy this file to .env and fill in your actual values.
# Never commit your .env file to version control.
#
#   cp .env.sample .env
# =============================================================


# -------------------------------------------------------------
# DJANGO CORE
# -------------------------------------------------------------

# A real generated key is shown below as an example of the correct format.
# DO NOT use this exact key in production — generate a fresh one with:
#
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#
# This key MUST be set. Django will refuse to start if it is missing from .env.
SECRET_KEY=4S(yE628xXi6f*p$57IKf!Gc+_HA7VV8T3+DWG@1T96sjJY&HX

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts
# Example: plateauriders.com,www.plateauriders.com
ALLOWED_HOSTS=localhost,127.0.0.1


# -------------------------------------------------------------
# DATABASE
# -------------------------------------------------------------
# SQLite is used by default (no config needed for dev).
# For PostgreSQL in production, uncomment and fill these:

# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=plateau_riders_db
# DB_USER=db_user
# DB_PASSWORD=db_password
# DB_HOST=localhost
# DB_PORT=5432


# -------------------------------------------------------------
# MONNIFY PAYMENT GATEWAY
# -------------------------------------------------------------
# Get these from your Monnify dashboard: https://monnify.com

MONNIFY_API_KEY=your-monnify-api-key
MONNIFY_SECRET_KEY=your-monnify-secret-key
MONNIFY_CONTRACT_CODE=your-monnify-contract-code

# Sandbox (testing):
MONNIFY_BASE_URL=https://sandbox.monnify.com

# Live (production) — switch when going live:
# MONNIFY_BASE_URL=https://api.monnify.com


# -------------------------------------------------------------
# EMAIL (optional — for booking confirmations)
# -------------------------------------------------------------
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=Plateau Riders <no-reply@plateauriders.com>


# -------------------------------------------------------------
# MEDIA & STATIC FILES (production)
# -------------------------------------------------------------
# STATIC_ROOT=/var/www/plateau_riders/static/
# MEDIA_ROOT=/var/www/plateau_riders/media/
